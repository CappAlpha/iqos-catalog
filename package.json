{
  "name": "iqos",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "tsc -b && vite build",
    "build:capacitor": "tsc -b && vite build --mode capacitor && npx cap sync",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,scss}\"",
    "preview": "vite preview",
    "lint-staged": "lint-staged",
    "prepare-pre-commit": "simple-git-hooks"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css,scss}": "prettier --write"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.2.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/preferences": "^8.0.1",
    "@tanstack/query-core": "^5.101.2",
    "axios": "^1.18.1",
    "capacitor-usb-serial": "^1.0.3",
    "classnames": "^2.5.1",
    "currency.js": "^2.0.4",
    "dompurify": "^3.4.11",
    "mobx": "^6.16.1",
    "mobx-react-lite": "^4.1.1",
    "mobx-tanstack-query": "^7.2.1",
    "nprogress": "^0.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@capacitor/cli": "^8.4.1",
    "@eslint-react/eslint-plugin": "^5.10.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.0.1",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/w3c-web-usb": "^1.0.14",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-mobx": "^0.0.14",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "knip": "^6.23.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "sass-embedded": "^1.100.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-svgr": "^5.2.0",
    "zod-validation-error": "^5.0.0"
  },
  "allowScripts": {
    "simple-git-hooks@2.13.1": true
  }
}
